{
  "name": "fortnite-island-ranking-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:e2e": "VITE_PROXY_DIRECT=1 vite --host 127.0.0.1 --port 5173",
    "preview:e2e": "npm run build && VITE_PROXY_DIRECT=1 vite preview --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "dompurify": "^3.3.1",
    "i18next": "^23.11.5",
    "marked": "^12.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^14.1.2",
    "react-router-dom": "^6.30.2",
    "recharts": "^3.5.1",
    "swr": "^2.3.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^3.2.4"
  }
}
