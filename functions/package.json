    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.2.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  }
}
