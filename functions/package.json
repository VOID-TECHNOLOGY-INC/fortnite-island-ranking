{
  "name": "fortnite-island-ranking-functions",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "npm run clean && npm run build && node --env-file=.env ./lib/dev-server.js",
